DEBUG=True
SECRET_KEY=
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Site configuration
SITE_DOMAIN=127.0.0.1:8000
SITE_NAME=DJ Jukebox Local

# Admin user (production only)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Spotify OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# yt-dlp cookies (local/dev)
# Option A: read cookies directly from browser profile (chrome/firefox)
YTDLP_COOKIES_FROM_BROWSER=
# Option B: explicit Netscape cookies.txt file path
YTDLP_COOKIES_FILE=

# Audio analysis limits (recommended for low-memory deploys like Render free)
ENABLE_YTDLP_FALLBACK=True
ANALYZE_YTDLP_PER_ATTEMPT_TIMEOUT=8
ANALYZE_YTDLP_MAX_WALL_SECONDS=18
ANALYZE_AUDIO_SECONDS=20
ANALYZE_AUDIO_SAMPLE_RATE=16000
SONGBPM_REQUEST_DELAY_SECONDS=4
SONGDATA_REQUEST_DELAY_SECONDS=6
SONGDATA_BLOCK_COOLDOWN_SECONDS=900

# Stripe payments
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email configuration
GMAIL_USER=
GMAIL_APP_PASSWORD=
